# fastlane lanes for shipping doku+ to the stores from CI.
# The web build + Capacitor sync happen in the workflow before these run, so the
# lanes only package and upload.

platform :android do
  desc "Build a signed AAB and upload to Play Store internal testing"
  lane :internal do
    gradle(
      project_dir: "android",
      task: "bundle",
      build_type: "Release"
    )

    json_key = ENV["PLAY_SERVICE_ACCOUNT_JSON"]
    if json_key && !json_key.strip.empty?
      upload_to_play_store(
        track: "internal",
        release_status: "draft",
        aab: "android/app/build/outputs/bundle/release/app-release.aab",
        json_key_data: json_key,
        skip_upload_apk: true,
        skip_upload_metadata: true,
        skip_upload_images: true,
        skip_upload_screenshots: true
      )
    else
      UI.important("PLAY_SERVICE_ACCOUNT_JSON not set — skipping Play Store upload.")
      UI.important("Signed AAB: android/app/build/outputs/bundle/release/app-release.aab")
      UI.important("Upload it manually via Play Console for the first release, then add the secret.")
    end
  end
end

platform :ios do
  # Manual code signing. Automatic signing can't work on an ephemeral CI runner
  # (it can't install the cert's private key), so we import an App Store
  # distribution certificate (.p12) and its provisioning profile from secrets.
  # The workflow decodes the assets and installs the profile; this lane imports
  # the cert into a throwaway keychain and builds with manual signing.
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    keychain_name = "dokuplus_ci.keychain"
    keychain_password = "ci"
    create_keychain(
      name: keychain_name,
      password: keychain_password,
      default_keychain: true,
      unlock: true,
      timeout: 1800,
      lock_when_sleeps: false
    )
    import_certificate(
      certificate_path: ENV["CERT_P12_PATH"],
      certificate_password: ENV["CERT_P12_PASSWORD"],
      keychain_name: keychain_name,
      keychain_password: keychain_password
    )

    profile_name = ENV["PROFILE_NAME"]
    build_app(
      project: "ios/App/App.xcodeproj",
      scheme: "App",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "ios/build",
      xcargs: [
        "CODE_SIGN_STYLE=Manual",
        "DEVELOPMENT_TEAM=#{ENV['APPLE_TEAM_ID']}",
        'CODE_SIGN_IDENTITY="Apple Distribution"',
        "PROVISIONING_PROFILE_SPECIFIER=\"#{profile_name}\""
      ].join(" "),
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: ENV["APPLE_TEAM_ID"],
        provisioningProfiles: {
          "app.dokuplus" => profile_name
        }
      }
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end
end
